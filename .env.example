# Copy this file to .env and fill in your values

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000          # Your Twilio number in E.164 format

CALENDLY_LINK=https://calendly.com/your-username/30min

# Optional: forward inbound calls to your real cell before the missed-call SMS fires
FORWARD_TO_NUMBER=+15551234567

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=change-me-in-production

# Leave blank to use SQLite (default). Set for Railway/Render Postgres if preferred.
# DATABASE_URL=postgresql://user:pass@host/dbname

PORT=5000
